// Wld 3D Sprite Definition
SPRITE3DDEF "tag"
	// Enable gouraud shading flag
	ENABLEGOURAUD2 1
	// Optional center offset
	CENTEROFFSET? 1.12345678 2.12345678 3.12345678
	// Number of vertices
	NUMVERTICES 1
		// Vertex position
		XYZ 1.12345678 2.12345678 3.12345678
	// Number of BSP nodes
	NUMBSPNODES 1
		// BSP node entry
		BSPNODE
		// Optional plane normal (A,B,C,D)
		NORMALABCD? 1.12345678 2.12345678 3.12345678 4.12345678
		// Vertex indices
		VERTEXLIST 3 0 1 2
		// Render method for node
		RENDERMETHOD "1"
		// Render configuration block
		RENDERINFO
			PEN? 1
			BRIGHTNESS? 1.12345678
			SCALEDAMBIENT? 1.12345678
			// Simple sprite instance block
			SIMPLESPRITEINST
				SIMPLESPRITETAG? "1"
				SIMPLESPRITETAGINDEX 1
				SIMPLESPRITEHAVESKIPFRAMES 1
				SIMPLESPRITESKIPFRAMES 1
			UVORIGIN? 1.12345678 2.12345678 3.12345678
			UAXIS? 1.12345678 2.12345678 3.12345678
			VAXIS? 1.12345678 2.12345678 3.12345678
			// Optional UV count
			NUMUVS? 1
				UV 1.12345678 2.12345678
			TWOSIDED 1
		FRONTTREE 1
		BACKTREE 1
	// Sphere list block
	SPHERELIST
		DEFINITION "1"
		SCALEFACTOR? 1.12345678
	BOUNDINGRADIUS? 1.12345678
